{
  "servers": {
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "env": {
        "MEMORY_FILE_PATH": "../.github/agents/knowledge-graph.jsonl"
      }
    },
    "stitch": {
      "url": "https://stitch.googleapis.com/mcp",
      "type": "http",
      "headers": {
        "Accept": "application/json",
        "X-Goog-Api-Key": "${input:googleApiKey}"
      }
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/insiders",
      "headers": {
        "X-MCP-Toolsets": "default,projects"
      }
    },
    "chrome-devtools-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "--registry",
        "https://registry.npmjs.org",
        "chrome-devtools-mcp@0.19.0"
      ]
    }
  },
  "inputs": [
    {
      "id": "googleApiKey",
      "type": "promptString",
      "description": "  Enter your Google API Key for MCP authentication",
      "password": true
    }
  ]
}